{
  "expo": {
    "name": "NusantaraLearn",
    "slug": "nusantaralearn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "nusantaralearn",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1120"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1120"
      },
      "package": "com.nusantaralearn.app",
      "minSdkVersion": 26,
      "targetSdkVersion": 34
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
